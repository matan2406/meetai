# MeetAI Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (Optional - for future MongoDB/PostgreSQL integration)
# DATABASE_URL=mongodb://localhost:27017/meetai
# DB_USER=admin
# DB_PASSWORD=your_password

# Twilio WhatsApp Configuration (for sending reminders)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=+14155552671

# JWT Secret (for future authentication)
# JWT_SECRET=your_jwt_secret_key_here

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# Email Configuration (for sending confirmations)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Admin Settings
ADMIN_EMAIL=admin@meetai.com
REMINDER_TIME_BEFORE=60
